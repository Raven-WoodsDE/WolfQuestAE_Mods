<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <RootNamespace>QualityOfLife</RootNamespace>
    <ImplicitUsings>disable</ImplicitUsings>
